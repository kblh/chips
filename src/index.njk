          <g class="logo__net">
            <circle cx="0" cy="-10" r="7" fill="var(--logo-node)" opacity="0.85" />
            <circle cx="0" cy="-10" r="3.5" fill="var(--logo-node-core)" />
            <polyline points="0,-10 -38,28" fill="none" stroke="var(--logo-node)" stroke-width="1.8"
              stroke-linecap="round" opacity="0.75" />
            <circle cx="-38" cy="28" r="4.5" fill="var(--logo-node)" opacity="0.75" />
            <polyline points="0,-10 38,28" fill="none" stroke="var(--logo-node)" stroke-width="1.8"
              stroke-linecap="round" opacity="0.75" />
            <circle cx="38" cy="28" r="4.5" fill="var(--logo-node)" opacity="0.75" />
            <polyline points="0,-10 0,-62" fill="none" stroke="var(--logo-node)" stroke-width="1.8"
